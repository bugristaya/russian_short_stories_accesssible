{
  "manifest_version": 3,
  "name": "Корпусный помощник",
  "version": "1.0.0",
  "description": "ИИ-ассистент для браузера. Голосовой поиск, анализ страниц и диалог по материалам Корпуса русского рассказа 1900–1930 гг.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Корпусный помощник"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "mermaid-render.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["assistant.html", "assistant.js", "assistant.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
